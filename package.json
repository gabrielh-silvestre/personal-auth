{
  "name": "personal-auth",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:eslint-fixtures": "ESLINT_USE_FLAT_CONFIG=false node scripts/check-eslint-fixtures.mjs",
    "test": "jest",
    "test:unit": "jest \".*\\.unit.spec\\.ts\"",
    "test:integration": "jest \".*\\.integration.spec\\.ts\"",
    "test:all": "jest --forceExit --config ./test/jest-all.config.js",
    "test:e2e": "jest --config ./test/jest-e2e.config.js",
    "test:cov": "jest --coverage --forceExit --config ./test/jest-all.config.js",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:watch": "jest --watch",
    "test:mutations": "stryker run --incremental"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",

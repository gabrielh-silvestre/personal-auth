    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-jest": "^0.0.1",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.5.0",
    "webpack": "^5.95.0"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13",

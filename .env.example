PORT=3001

DB_NAME=database

MONGO_PORT=27017
MONGO_URI=mongodb://localhost:${MONGO_PORT}/${DB_NAME}

JWT_ACCESS_TOKEN_SECRET=secret
JWT_ACCESS_TOKEN_EXPIRES_IN=900000

JWT_REFRESH_TOKEN_SECRET=secret
JWT_REFRESH_TOKEN_EXPIRES_IN=604800000

RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@localhost:${RABBITMQ_PORT}

# --- OpenTelemetry (opt-in) ---
OTEL_ENABLED=false
OTEL_SERVICE_NAME=personal-auth
OTEL_SERVICE_VERSION=0.0.1
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://otel-collector:4318/v1/logs
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_TRACES_SAMPLER_ARG=
# NOTE: parentbased_always_on honors upstream traceparent's sampled bit.
# If an authenticated upstream service sends sampled=0 (e.g. its own sampler dropped),
# personal-auth will ALSO drop the resulting span — including error spans on the auth path.
# For security-investigation deployments or when upstream samplers are unknown/untrusted,
# set OTEL_TRACES_SAMPLER=always_on to match droz's "every span" guarantee.
OTEL_LOG_LEVEL=info
# Set to DEBUG to auto-append a ConsoleSpanExporter alongside OTLP.
OTEL_METRIC_EXPORT_INTERVAL_MS=60000
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
# Comma-separated names of instrumentations to disable at preload time (e.g., fs,dns,net).
# Honored by auto-instrumentations.ts when present; empty by default.
OTEL_NODE_DISABLED_INSTRUMENTATIONS=
